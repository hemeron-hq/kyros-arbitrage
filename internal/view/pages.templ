								}
								@table.Cell(table.CellProps{Class: "align-top"}) {
									<span class="whitespace-nowrap font-mono text-xs tabular-nums">{ row.MinNotional }</span>
								}
								@table.Cell(table.CellProps{Class: "align-top"}) {
