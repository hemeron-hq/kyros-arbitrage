templ ConnectionDashboard(connection ConnectionTermsView) {
	<div id="connections-dashboard" class="grid min-w-0 gap-3">
		@ConnectionSummaryCard(connection.SummaryRows, connection.LastUpdated)
		@ConnectionRulesCard(connection.RuleRows)
		<section class="grid min-w-0 gap-3 2xl:grid-cols-2">
			@ConnectionBalancesCard(connection.BalanceRows)
			@ConnectionTransferFeesCard(connection.TransferRows)
		</section>
	</div>
}

templ ConnectionSummaryCard(rows []ConnectionSummaryRow, lastUpdated string) {
	@card.Card(card.Props{Class: "terminal-card min-w-0 overflow-hidden border-0 bg-transparent shadow-none"}) {
		@card.Header(card.HeaderProps{Class: "px-4 pt-4 pb-3"}) {
			<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
				<div class="flex min-w-0 items-start gap-2">
					<span class="terminal-panel-icon mt-0.5 grid size-7 shrink-0 place-items-center rounded-md">
						@icon.Unplug(icon.Props{Class: "size-4"})
					</span>
					<div class="min-w-0">
						@card.Title() {
							Exchange connections
						}
						@card.Description() {
							Read-only credential state and terms freshness from environment-configured exchanges.
						}
					</div>
				</div>
				<span class="font-mono text-xs text-muted-foreground">{ lastUpdated }</span>
			</div>
		}
		@card.Content(card.ContentProps{Class: "px-4 pb-4 pt-0"}) {
			<div class="terminal-table w-full max-w-full overflow-x-auto rounded-lg border-0" tabindex="0">
				@table.Table(table.Props{Class: "min-w-[900px] table-fixed"}) {
					@table.Header() {
						@table.Row() {
							@table.Head(table.HeadProps{Class: "w-[130px]"}) {
								Exchange
							}
							@table.Head(table.HeadProps{Class: "w-[100px]"}) {
								Market
							}
							@table.Head(table.HeadProps{Class: "w-[120px]"}) {
								Source
							}
							@table.Head(table.HeadProps{Class: "w-[100px]"}) {
								Status
							}
							@table.Head(table.HeadProps{Class: "w-[150px]"}) {
								Updated
							}
							@table.Head(table.HeadProps{Class: "w-[150px]"}) {
								Expires
							}
							@table.Head(table.HeadProps{Class: "w-[250px]"}) {
								Message
							}
						}
					}
					@table.Body() {
						if len(rows) == 0 {
							@table.Row() {
								<td colspan="7" class="p-4 text-sm text-muted-foreground">
									No exchange terms have been loaded yet.
								</td>
							}
						}
						for _, row := range rows {
							@table.Row() {
								@table.Cell(table.CellProps{Class: "align-top"}) {
									<span class="font-medium">{ row.Exchange }</span>
								}
								@table.Cell(table.CellProps{Class: "align-top"}) {
									<span class="whitespace-nowrap font-mono text-xs">{ row.Market }</span>
								}
								@table.Cell(table.CellProps{Class: "align-top"}) {
									@badge.Badge(badge.Props{Variant: badge.VariantOutline, Class: "terminal-badge"}) {
										{ row.Source }
									}
								}
								@table.Cell(table.CellProps{Class: "align-top"}) {
									<span class="whitespace-nowrap text-xs">{ row.Status }</span>
								}
								@table.Cell(table.CellProps{Class: "align-top"}) {
									<span class="whitespace-nowrap font-mono text-xs">{ row.Updated }</span>
								}
								@table.Cell(table.CellProps{Class: "align-top"}) {
									<span class="whitespace-nowrap font-mono text-xs">{ row.Expires }</span>
								}
								@table.Cell(table.CellProps{Class: "align-top"}) {
									<span class="block truncate text-xs text-muted-foreground">{ row.Message }</span>
								}
							}
						}
					}
				}
			</div>
		}
	}
}

templ ConnectionRulesCard(rows []ConnectionRuleRow) {
	@card.Card(card.Props{Class: "terminal-card min-w-0 overflow-hidden border-0 bg-transparent shadow-none"}) {
		@card.Header(card.HeaderProps{Class: "px-4 pt-4 pb-3"}) {
