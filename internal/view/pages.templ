package view

import (
	"strconv"

	"github.com/templui/templui/components/badge"
	"github.com/templui/templui/components/button"
	"github.com/templui/templui/components/card"
	"github.com/templui/templui/components/icon"
	"github.com/templui/templui/components/table"
	"github.com/templui/templui/components/tabs"
)

templ Page(model PageModel) {
	<!DOCTYPE html>
	<html lang="en">
		@Head(model.Title)
		<body class="min-h-screen bg-background text-foreground antialiased">
			<main
				id="dashboard"
				class="mx-auto flex min-h-screen w-full max-w-[1800px] flex-col gap-3 px-3 py-3 sm:px-4 lg:px-5 2xl:px-6"
				data-signals={ templ.JSONString(DashboardSignals{
					Connected: model.Heartbeat.Connected,
					ServerTime: model.Heartbeat.ServerTime,
					Ticks: model.Heartbeat.Ticks,
					Streaming: false,
					LiveFeeds: model.Live.LiveFeeds,
					StaleFeeds: model.Live.StaleFeeds,
				}) }
				data-init="@get('/stream', {openWhenHidden: true})"
			>
				<header class="terminal-topbar flex flex-col gap-4 rounded-lg border-0 px-4 py-3 md:flex-row md:items-center md:justify-between">
					<div class="flex min-w-0 items-start gap-3">
						<div class="terminal-icon-shell mt-0.5 grid size-8 shrink-0 place-items-center rounded-lg text-primary">
							@icon.Radar(icon.Props{Class: "size-4"})
						</div>
						<div class="min-w-0 space-y-2">
						<div class="flex flex-wrap items-center gap-2">
							@badge.Badge(badge.Props{Variant: badge.VariantSecondary, Class: "terminal-badge"}) {
								@icon.Activity(icon.Props{Class: "size-3"})
								Realtime feeds
							}
							@badge.Badge(badge.Props{Variant: badge.VariantOutline, Class: "terminal-badge"}) {
								BTC/USDT
							}
						</div>
						<div>
							<h1 class="text-2xl font-semibold tracking-normal sm:text-3xl">Kyros Arbitrage</h1>
							<p class="max-w-2xl text-sm text-muted-foreground">
								Live order books, net profitability scoring, and autonomous paper execution.
							</p>
						</div>
					</div>
					</div>
					<div class="flex items-center gap-3">
						<div class="text-left text-xs text-muted-foreground md:text-right">
							<div>Started</div>
							<div class="font-mono text-foreground">{ model.StartedAt }</div>
						</div>
						@button.Button(button.Props{
							Variant: button.VariantSecondary,
							Class: "h-9 rounded-lg border-0 bg-foreground px-4 text-background shadow-none hover:bg-foreground/90",
							Attributes: templ.Attributes{
								"data-on:click": "@get('/stream')",
								"data-indicator:streaming": "",
								"data-attr:disabled": "$streaming",
							},
						}) {
							@icon.RotateCcw(icon.Props{Class: "size-4"})
							Reconnect
						}
					</div>
				</header>

				@MetricStrip(model.Live)

				@tabs.Tabs(tabs.Props{ID: "dashboard-tabs", Class: "min-w-0 gap-3"}) {
					@tabs.List(tabs.ListProps{Class: "terminal-tabs min-w-0 max-w-full overflow-x-auto rounded-lg border-0 p-1"}) {
						@tabs.Trigger(tabs.TriggerProps{Value: "overview", IsActive: true, Class: "gap-2 px-3"}) {
							@icon.LayoutDashboard(icon.Props{Class: "size-4"})
							Overview
						}
						@tabs.Trigger(tabs.TriggerProps{Value: "connections", Class: "gap-2 px-3"}) {
							@icon.Unplug(icon.Props{Class: "size-4"})
							Connections
						}
					}
					@tabs.Content(tabs.ContentProps{Value: "overview", IsActive: true}) {
						<section class="grid min-w-0 items-start gap-3 xl:grid-cols-[minmax(0,1fr)_340px]">
							<div class="min-w-0">
								@LiveDashboard(model.Live)
								</div>
								<div class="min-w-0 xl:sticky xl:top-3">
									@HeartbeatPanel(model.Heartbeat)
									@RiskPanel(model.Live.Risk)
								</div>
							</section>
						}
					@tabs.Content(tabs.ContentProps{Value: "connections"}) {
						@ConnectionDashboard(model.Live.Connection)
					}
				}
			</main>
		</body>
	</html>
}

templ Head(title string) {
	<head>
		<meta charset="utf-8"/>
		<meta name="viewport" content="width=device-width, initial-scale=1"/>
		<title>{ title }</title>
		<link rel="stylesheet" href="/assets/css/output.css"/>
		<script type="module" src="/assets/js/datastar.js"></script>
		@tabs.Script()
	</head>
}

templ MetricStrip(live LiveDashboardView) {
	<section id="metric-strip" class="grid min-w-0 gap-2 sm:grid-cols-2 lg:grid-cols-6">
		@MetricCard("Live feeds", strconv.Itoa(live.LiveFeeds), "Backend market streams.", "radio")
		@MetricCard("Best net P&L", live.BestNetPnl, live.BestNetState, "trending-up")
		@MetricCard("Session P&L", live.SessionPnl, live.Executed + " simulated fills", "wallet-cards")
		@MetricCard("History P&L", live.History.TotalPnl, live.History.ExecutionCount + " stored trades", "history")
		@MetricCard("Rejected", live.Rejected, "Current decision pass.", "circle-alert")
		@MetricCard("Stale/error feeds", strconv.Itoa(live.StaleFeeds), "Fallback and reconnect state.", "wifi-off")
	</section>
}

templ MetricCard(label string, value string, detail string, iconName string) {
	@card.Card(card.Props{Class: "terminal-card min-w-0 border-0 bg-transparent shadow-none"}) {
		@card.Content(card.ContentProps{Class: "p-4"}) {
			<div class="min-w-0 space-y-1">
				<div class="flex items-center gap-2 text-xs uppercase text-muted-foreground">
					<span class="terminal-mini-icon grid size-5 shrink-0 place-items-center rounded-md">
						@icon.Icon(iconName)(icon.Props{Class: "size-3.5"})
					</span>
					<span>{ label }</span>
				</div>
				<div class="font-mono text-xl font-semibold tracking-normal text-foreground">{ value }</div>
				<div class="break-words text-xs text-muted-foreground">{ detail }</div>
			</div>
		}
	}
}

templ HeartbeatPanel(heartbeat HeartbeatView) {
	@card.Card(card.Props{ID: "heartbeat-panel", Class: "terminal-card min-w-0 overflow-hidden border-0 bg-transparent shadow-none"}) {
		@card.Header(card.HeaderProps{Class: "px-4 pt-4 pb-3"}) {
			<div class="flex items-start justify-between gap-3">
				<div class="flex min-w-0 items-start gap-2">
					<span class="terminal-panel-icon mt-0.5 grid size-7 shrink-0 place-items-center rounded-md">
						@icon.Server(icon.Props{Class: "size-4"})
					</span>
					<div class="min-w-0">
					@card.Title() {
						System heartbeat
					}
					@card.Description() {
						Server stream and process uptime.
					}
					</div>
				</div>
				@badge.Badge(badge.Props{Variant: badge.VariantSecondary, Class: "terminal-badge flex items-center gap-2"}) {
					<span class={ "size-2 rounded-full " + heartbeat.StatusClass }></span>
					<span>{ heartbeat.StatusLabel }</span>
				}
			</div>
		}
		@card.Content(card.ContentProps{Class: "px-4 pb-4 pt-0"}) {
			<dl class="grid grid-cols-1 gap-2 text-sm sm:grid-cols-2 xl:grid-cols-1 2xl:grid-cols-2">
				<div class="terminal-stat rounded-lg border-0 p-3">
					<dt class="text-muted-foreground">Server time</dt>
					<dd class="mt-1 break-words font-mono text-xs" data-text="$serverTime">{ heartbeat.ServerTime }</dd>
				</div>
				<div class="terminal-stat rounded-lg border-0 p-3">
					<dt class="text-muted-foreground">Heartbeats</dt>
					<dd class="mt-1 font-mono text-lg font-semibold" data-text="$ticks">{ heartbeat.TicksLabel }</dd>
				</div>
				<div class="terminal-stat rounded-lg border-0 p-3">
					<dt class="text-muted-foreground">Uptime</dt>
					<dd class="mt-1 font-mono text-xs">{ heartbeat.Uptime }</dd>
				</div>
				<div class="terminal-stat rounded-lg border-0 p-3">
					<dt class="text-muted-foreground">Transport</dt>
					<dd class="mt-1 font-medium">SSE</dd>
				</div>
			</dl>
		}
	}
}

templ RiskPanel(risk RiskView) {
	@card.Card(card.Props{ID: "risk-panel", Class: "terminal-card mt-3 min-w-0 overflow-hidden border-0 bg-transparent shadow-none"}) {
		@card.Header(card.HeaderProps{Class: "px-4 pt-4 pb-3"}) {
			<div class="flex items-start justify-between gap-3">
				<div class="flex min-w-0 items-start gap-2">
					<span class="terminal-panel-icon mt-0.5 grid size-7 shrink-0 place-items-center rounded-md">
						@icon.ShieldAlert(icon.Props{Class: "size-4"})
					</span>
					<div class="min-w-0">
						@card.Title() {
							Risk controls
						}
						@card.Description() {
							Persisted circuit mode and execution guards.
						}
					</div>
				</div>
				@badge.Badge(badge.Props{Variant: badge.VariantOutline, Class: "terminal-badge flex items-center gap-2"}) {
					<span class={ "size-2 rounded-full " + risk.StatusClass }></span>
					<span>{ risk.Status }</span>
				}
			</div>
		}
		@card.Content(card.ContentProps{Class: "px-4 pb-4 pt-0"}) {
			<form method="post" action="/api/risk/mode" class="grid gap-3">
				<div class="grid grid-cols-3 gap-1 rounded-lg p-1 terminal-stat">
					@RiskModeButton("conservative", "Conservative", risk.ConservativeActive)
					@RiskModeButton("balanced", "Balanced", risk.BalancedActive)
					@RiskModeButton("aggressive", "Aggressive", risk.AggressiveActive)
				</div>
				<dl class="grid grid-cols-2 gap-2 text-sm">
					<div class="terminal-stat rounded-lg border-0 p-3">
						<dt class="text-muted-foreground">Max spread</dt>
						<dd class="mt-1 font-mono text-xs">{ risk.MaxSpread }</dd>
					</div>
					<div class="terminal-stat rounded-lg border-0 p-3">
						<dt class="text-muted-foreground">Max latency</dt>
						<dd class="mt-1 font-mono text-xs">{ risk.MaxLatencyPenalty }</dd>
					</div>
					<div class="terminal-stat rounded-lg border-0 p-3">
						<dt class="text-muted-foreground">Drawdown</dt>
						<dd class="mt-1 font-mono text-xs">{ risk.MaxDrawdown }</dd>
					</div>
					<div class="terminal-stat rounded-lg border-0 p-3">
						<dt class="text-muted-foreground">Reserve</dt>
						<dd class="mt-1 font-mono text-xs">{ risk.Reserve }</dd>
					</div>
				</dl>
				<div class="space-y-1 text-xs text-muted-foreground">
					for _, reason := range risk.Reasons {
						<div class="break-words font-mono">{ reason }</div>
					}
				</div>
			</form>
		}
	}
}

templ RiskModeButton(value string, label string, active bool) {
	<button
		type="submit"
		name="mode"
		value={ value }
		class={ "h-8 rounded-md px-2 text-xs font-medium transition " + riskModeButtonClass(active) }
	>
		{ label }
	</button>
}

func riskModeButtonClass(active bool) string {
	if active {
		return "bg-foreground text-background"
	}
	return "text-muted-foreground hover:text-foreground"
}

templ LiveDashboard(live LiveDashboardView) {
	<div id="live-dashboard" class="grid min-w-0 gap-3">
		@FeedCard(live.FeedRows, live.LastUpdated)
		@OpportunityCard(live.OpportunityRows)
		@HistoryCard(live.History)
		<section class="grid min-w-0 gap-3 2xl:grid-cols-2">
			@TermsSourceCard(live.TermsRows)
			@BalanceCard(live.BalanceRows)
		</section>
	</div>
}

templ FeedCard(rows []FeedRow, lastUpdated string) {
	@card.Card(card.Props{Class: "terminal-card min-w-0 overflow-hidden border-0 bg-transparent shadow-none"}) {
		@card.Header(card.HeaderProps{Class: "px-4 pt-4 pb-3"}) {
			<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
				<div class="flex min-w-0 items-start gap-2">
					<span class="terminal-panel-icon mt-0.5 grid size-7 shrink-0 place-items-center rounded-md">
						@icon.Radio(icon.Props{Class: "size-4"})
					</span>
					<div class="min-w-0">
					@card.Title() {
						Exchange feeds
					}
					@card.Description() {
						Top 10 levels from public BTC/USDT books.
					}
					</div>
				</div>
				<span class="font-mono text-xs text-muted-foreground">{ lastUpdated }</span>
			</div>
		}
		@card.Content(card.ContentProps{Class: "px-4 pb-4 pt-0"}) {
			<div class="terminal-table w-full max-w-full overflow-x-auto rounded-lg border-0" tabindex="0">
				@table.Table(table.Props{Class: "min-w-[860px] table-fixed"}) {
					@table.Header() {
						@table.Row() {
							@table.Head(table.HeadProps{Class: "w-[150px]"}) {
								Exchange
							}
							@table.Head(table.HeadProps{Class: "w-[100px]"}) {
								Market
							}
							@table.Head(table.HeadProps{Class: "w-[130px]"}) {
								Bid
							}
							@table.Head(table.HeadProps{Class: "w-[130px]"}) {
								Ask
							}
							@table.Head(table.HeadProps{Class: "w-[80px]"}) {
								Levels
							}
							@table.Head(table.HeadProps{Class: "w-[110px]"}) {
								Age
							}
							@table.Head(table.HeadProps{Class: "w-[110px]"}) {
								Latency
							}
							@table.Head(table.HeadProps{Class: "w-[120px]"}) {
								Transport
							}
						}
					}
					@table.Body() {
						for _, row := range rows {
							@table.Row() {
								@table.Cell(table.CellProps{Class: "align-top"}) {
									<div class="flex min-w-0 items-center gap-2">
										<span class={ "size-2 rounded-full " + row.StatusClass }></span>
										<div class="min-w-0">
											<div class="truncate font-medium">{ row.Exchange }</div>
											<div class="truncate text-xs text-muted-foreground">{ row.Status }</div>
										</div>
									</div>
								}
								@table.Cell(table.CellProps{Class: "align-top"}) {
									<span class="whitespace-nowrap font-mono text-xs tabular-nums">{ row.Market }</span>
								}
								@table.Cell(table.CellProps{Class: "align-top"}) {
									<div class="whitespace-nowrap font-mono text-sm tabular-nums">{ row.Bid }</div>
									<div class="whitespace-nowrap font-mono text-xs tabular-nums text-muted-foreground">{ row.BidSize }</div>
								}
								@table.Cell(table.CellProps{Class: "align-top"}) {
									<div class="whitespace-nowrap font-mono text-sm tabular-nums">{ row.Ask }</div>
									<div class="whitespace-nowrap font-mono text-xs tabular-nums text-muted-foreground">{ row.AskSize }</div>
								}
								@table.Cell(table.CellProps{Class: "align-top"}) {
									<span class="whitespace-nowrap font-mono text-xs tabular-nums">{ row.Levels }</span>
								}
								@table.Cell(table.CellProps{Class: "align-top"}) {
									<span class="whitespace-nowrap font-mono text-xs tabular-nums">{ row.Age }</span>
								}
								@table.Cell(table.CellProps{Class: "align-top"}) {
									<span class="whitespace-nowrap font-mono text-xs tabular-nums">{ row.Latency }</span>
								}
								@table.Cell(table.CellProps{Class: "align-top"}) {
									@badge.Badge(badge.Props{Variant: badge.VariantOutline, Class: "terminal-badge"}) {
										{ row.Transport }
									}
								}
							}
						}
					}
				}
			</div>
		}
	}
}

templ OpportunityCard(rows []OpportunityRow) {
	@card.Card(card.Props{Class: "terminal-card min-w-0 overflow-hidden border-0 bg-transparent shadow-none"}) {
		@card.Header(card.HeaderProps{Class: "px-4 pt-4 pb-3"}) {
			<div class="flex min-w-0 items-start gap-2">
				<span class="terminal-panel-icon mt-0.5 grid size-7 shrink-0 place-items-center rounded-md">
					@icon.TrendingUp(icon.Props{Class: "size-4"})
				</span>
				<div class="min-w-0">
			@card.Title() {
				Decision engine
			}
			@card.Description() {
				Net profitability after fees, slippage, latency, and simulated wallet constraints.
			}
				</div>
			</div>
		}
		@card.Content(card.ContentProps{Class: "px-4 pb-4 pt-0"}) {
			<div class="terminal-table w-full max-w-full overflow-x-auto rounded-lg border-0" tabindex="0">
				@table.Table(table.Props{Class: "min-w-[1040px] table-fixed"}) {
					@table.Header() {
						@table.Row() {
							@table.Head(table.HeadProps{Class: "w-[170px]"}) {
								Route
							}
							@table.Head(table.HeadProps{Class: "w-[100px]"}) {
								Market
							}
							@table.Head(table.HeadProps{Class: "w-[130px]"}) {
								Size
							}
							@table.Head(table.HeadProps{Class: "w-[100px]"}) {
								Gross
							}
							@table.Head(table.HeadProps{Class: "w-[130px]"}) {
								Fees
							}
							@table.Head(table.HeadProps{Class: "w-[120px]"}) {
								Slippage
							}
							@table.Head(table.HeadProps{Class: "w-[120px]"}) {
								Latency
							}
							@table.Head(table.HeadProps{Class: "w-[120px]"}) {
								Rebalance
							}
							@table.Head(table.HeadProps{Class: "w-[130px]"}) {
								Net P&L
							}
							@table.Head(table.HeadProps{Class: "w-[130px]"}) {
								Decision
							}
							@table.Head(table.HeadProps{Class: "w-[190px]"}) {
								Reason
							}
						}
					}
					@table.Body() {
						for _, row := range rows {
							@table.Row() {
								@table.Cell(table.CellProps{Class: "align-top"}) {
									<span class="block truncate font-medium">{ row.Route }</span>
								}
								@table.Cell(table.CellProps{Class: "align-top"}) {
									<span class="whitespace-nowrap font-mono text-xs tabular-nums">{ row.Market }</span>
								}
								@table.Cell(table.CellProps{Class: "align-top"}) {
									<span class="whitespace-nowrap font-mono text-xs tabular-nums">{ row.Size }</span>
								}
								@table.Cell(table.CellProps{Class: "align-top"}) {
									<span class="whitespace-nowrap font-mono text-xs tabular-nums">{ row.GrossPnl }</span>
								}
								@table.Cell(table.CellProps{Class: "align-top"}) {
									<span class="whitespace-nowrap font-mono text-xs tabular-nums">{ row.Fees }</span>
								}
								@table.Cell(table.CellProps{Class: "align-top"}) {
									<span class="whitespace-nowrap font-mono text-xs tabular-nums">{ row.Slippage }</span>
								}
								@table.Cell(table.CellProps{Class: "align-top"}) {
									<span class="whitespace-nowrap font-mono text-xs tabular-nums">{ row.Latency }</span>
								}
								@table.Cell(table.CellProps{Class: "align-top"}) {
									<span class="whitespace-nowrap font-mono text-xs tabular-nums">{ row.Rebalance }</span>
								}
								@table.Cell(table.CellProps{Class: "align-top"}) {
									<span class="whitespace-nowrap font-mono text-sm tabular-nums">{ row.ExpectedNet }</span>
								}
								@table.Cell(table.CellProps{Class: "align-top"}) {
									@badge.Badge(badge.Props{Variant: badge.VariantOutline, Class: "terminal-badge"}) {
										{ row.Decision }
									}
								}
								@table.Cell(table.CellProps{Class: "align-top"}) {
									<span class="block truncate font-mono text-xs">{ row.Reason }</span>
								}
							}
						}
					}
				}
			</div>
		}
	}
}

templ HistoryCard(history HistoryView) {
	@card.Card(card.Props{Class: "terminal-card min-w-0 overflow-hidden border-0 bg-transparent shadow-none"}) {
		@card.Header(card.HeaderProps{Class: "px-4 pt-4 pb-3"}) {
			<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
				<div class="flex min-w-0 items-start gap-2">
					<span class="terminal-panel-icon mt-0.5 grid size-7 shrink-0 place-items-center rounded-md">
						@icon.Database(icon.Props{Class: "size-4"})
					</span>
					<div class="min-w-0">
					@card.Title() {
						Persistent history
					}
					@card.Description() {
						Stored opportunities, simulated fills, and accumulated P&L.
					}
					</div>
				</div>
				<div class="text-left text-xs text-muted-foreground sm:text-right">
					<div>{ history.Status }</div>
					<div class="max-w-[420px] truncate font-mono">{ history.Path }</div>
				</div>
			</div>
		}
		@card.Content(card.ContentProps{Class: "px-4 pb-4 pt-0"}) {
			<div class="grid gap-3">
				<dl class="grid grid-cols-1 gap-2 text-sm sm:grid-cols-3">
					<div class="terminal-stat rounded-lg border-0 p-3">
						<dt class="text-muted-foreground">Stored opportunities</dt>
						<dd class="mt-1 font-mono text-lg font-semibold">{ history.OpportunityCount }</dd>
					</div>
					<div class="terminal-stat rounded-lg border-0 p-3">
						<dt class="text-muted-foreground">Stored trades</dt>
						<dd class="mt-1 font-mono text-lg font-semibold">{ history.ExecutionCount }</dd>
					</div>
					<div class="terminal-stat rounded-lg border-0 p-3">
						<dt class="text-muted-foreground">Accumulated P&L</dt>
						<dd class="mt-1 font-mono text-lg font-semibold">{ history.TotalPnl }</dd>
					</div>
				</dl>

				<div class="grid gap-3 2xl:grid-cols-2">
					<div class="min-w-0">
						<div class="mb-2 text-sm font-medium">Recent simulated fills</div>
						<div class="terminal-table w-full max-w-full overflow-x-auto rounded-lg border-0" tabindex="0">
							@table.Table(table.Props{Class: "min-w-[760px] table-fixed"}) {
								@table.Header() {
									@table.Row() {
										@table.Head(table.HeadProps{Class: "w-[150px]"}) {
											Time
										}
										@table.Head(table.HeadProps{Class: "w-[160px]"}) {
											Route
										}
										@table.Head(table.HeadProps{Class: "w-[90px]"}) {
											Market
										}
										@table.Head(table.HeadProps{Class: "w-[110px]"}) {
											Size
										}
										@table.Head(table.HeadProps{Class: "w-[110px]"}) {
											Net P&L
										}
										@table.Head(table.HeadProps{Class: "w-[110px]"}) {
											Terms
										}
									}
								}
								@table.Body() {
									if len(history.ExecutionRows) == 0 {
										@table.Row() {
											<td colspan="6" class="p-4 text-sm text-muted-foreground">
												No simulated fills have been persisted yet.
											</td>
										}
									}
									for _, row := range history.ExecutionRows {
										@table.Row() {
											@table.Cell(table.CellProps{Class: "align-top"}) {
												<span class="whitespace-nowrap font-mono text-xs">{ row.Executed }</span>
											}
											@table.Cell(table.CellProps{Class: "align-top"}) {
												<span class="block truncate font-medium">{ row.Route }</span>
											}
											@table.Cell(table.CellProps{Class: "align-top"}) {
												<span class="whitespace-nowrap font-mono text-xs">{ row.Market }</span>
											}
											@table.Cell(table.CellProps{Class: "align-top"}) {
												<span class="whitespace-nowrap font-mono text-xs tabular-nums">{ row.Size }</span>
											}
											@table.Cell(table.CellProps{Class: "align-top"}) {
												<span class="whitespace-nowrap font-mono text-sm tabular-nums">{ row.NetProfit }</span>
											}
											@table.Cell(table.CellProps{Class: "align-top"}) {
												<span class="text-xs text-muted-foreground">{ row.TermsSource }</span>
											}
										}
									}
								}
							}
						</div>
					</div>

					<div class="min-w-0">
						<div class="mb-2 text-sm font-medium">Recent detected opportunities</div>
						<div class="terminal-table w-full max-w-full overflow-x-auto rounded-lg border-0" tabindex="0">
							@table.Table(table.Props{Class: "min-w-[820px] table-fixed"}) {
								@table.Header() {
									@table.Row() {
										@table.Head(table.HeadProps{Class: "w-[150px]"}) {
											Time
										}
										@table.Head(table.HeadProps{Class: "w-[160px]"}) {
											Route
										}
										@table.Head(table.HeadProps{Class: "w-[90px]"}) {
											Market
										}
										@table.Head(table.HeadProps{Class: "w-[110px]"}) {
											Size
										}
										@table.Head(table.HeadProps{Class: "w-[110px]"}) {
											Net P&L
										}
										@table.Head(table.HeadProps{Class: "w-[110px]"}) {
											Decision
										}
										@table.Head(table.HeadProps{Class: "w-[160px]"}) {
											Reason
										}
									}
								}
								@table.Body() {
									if len(history.OpportunityRows) == 0 {
										@table.Row() {
											<td colspan="7" class="p-4 text-sm text-muted-foreground">
												No opportunities have been persisted yet.
											</td>
										}
									}
									for _, row := range history.OpportunityRows {
										@table.Row() {
											@table.Cell(table.CellProps{Class: "align-top"}) {
												<span class="whitespace-nowrap font-mono text-xs">{ row.Observed }</span>
											}
											@table.Cell(table.CellProps{Class: "align-top"}) {
												<span class="block truncate font-medium">{ row.Route }</span>
											}
											@table.Cell(table.CellProps{Class: "align-top"}) {
												<span class="whitespace-nowrap font-mono text-xs">{ row.Market }</span>
											}
											@table.Cell(table.CellProps{Class: "align-top"}) {
												<span class="whitespace-nowrap font-mono text-xs tabular-nums">{ row.Size }</span>
											}
											@table.Cell(table.CellProps{Class: "align-top"}) {
												<span class="whitespace-nowrap font-mono text-sm tabular-nums">{ row.ExpectedNet }</span>
											}
											@table.Cell(table.CellProps{Class: "align-top"}) {
												@badge.Badge(badge.Props{Variant: badge.VariantOutline, Class: "terminal-badge"}) {
													{ row.Decision }
												}
											}
											@table.Cell(table.CellProps{Class: "align-top"}) {
												<span class="block truncate font-mono text-xs">{ row.Reason }</span>
											}
										}
									}
								}
							}
						</div>
					</div>
				</div>
			</div>
		}
	}
}

templ TermsSourceCard(rows []TermsSourceRow) {
	@card.Card(card.Props{Class: "terminal-card min-w-0 overflow-hidden border-0 bg-transparent shadow-none"}) {
